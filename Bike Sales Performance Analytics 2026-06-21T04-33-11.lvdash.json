{
  "datasets": [
    {
      "name": "customer_value",
      "displayName": "Customer Lifetime Value",
      "config": {
        "version": "1.1",
        "source": "workspace.gold.gold_customer_lifetime_value",
        "dimensions": [
          {
            "name": "c_custkey",
            "expr": "c_custkey"
          },
          {
            "name": "c_name",
            "expr": "c_name",
            "displayName": "Customer Name"
          },
          {
            "name": "first_order_date",
            "expr": "first_order_date",
            "displayName": "First Order Date"
          },
          {
            "name": "last_order_date",
            "expr": "last_order_date",
            "displayName": "Last Order Date"
          },
          {
            "name": "value_segment",
            "expr": "value_segment",
            "displayName": "Value Segment"
          }
        ],
        "measures": [
          {
            "name": "total_orders",
            "expr": "SUM(total_orders)",
            "displayName": "Total Orders"
          },
          {
            "name": "total_revenue",
            "expr": "SUM(total_revenue)",
            "displayName": "Total Revenue",
            "format": {
              "type": "currency",
              "currencyCode": "USD",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              },
              "abbreviation": "compact"
            }
          },
          {
            "name": "average_order_value",
            "expr": "SUM(total_revenue) / SUM(total_orders)",
            "displayName": "Average Order Value",
            "format": {
              "type": "currency",
              "currencyCode": "USD",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            }
          },
          {
            "name": "customer_count",
            "expr": "COUNT(DISTINCT c_custkey)",
            "displayName": "Total Customers"
          }
        ]
      }
    },
    {
      "name": "regional_revenue",
      "displayName": "Regional Revenue by Month",
      "config": {
        "version": "1.1",
        "source": "workspace.gold.gold_monthly_revenue_by_region",
        "dimensions": [
          {
            "name": "region_name",
            "expr": "region_name",
            "displayName": "Region"
          },
          {
            "name": "order_year",
            "expr": "order_year",
            "displayName": "Year"
          },
          {
            "name": "order_month",
            "expr": "order_month",
            "displayName": "Month"
          },
          {
            "name": "year_month",
            "expr": "CONCAT(CAST(order_year AS STRING), '-', LPAD(CAST(order_month AS STRING), 2, '0'))",
            "displayName": "Year-Month"
          }
        ],
        "measures": [
          {
            "name": "revenue",
            "expr": "SUM(revenue)",
            "displayName": "Revenue",
            "format": {
              "type": "currency",
              "currencyCode": "USD",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              },
              "abbreviation": "compact"
            }
          }
        ]
      }
    },
    {
      "name": "top_products",
      "displayName": "Top Products by Revenue",
      "config": {
        "source": "workspace.gold.gold_top_products",
        "measures": [
          {
            "name": "total_revenue",
            "expr": "SUM(total_revenue)",
            "displayName": "Total Revenue",
            "format": {
              "type": "currency",
              "currencyCode": "USD",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              }
            }
          },
          {
            "name": "total_quantity",
            "expr": "SUM(total_quantity)",
            "displayName": "Total Quantity"
          },
          {
            "name": "order_count",
            "expr": "SUM(order_count)",
            "displayName": "Order Count"
          }
        ],
        "filter": "revenue_rank <= 10",
        "version": "1.1",
        "dimensions": [
          {
            "name": "p_partkey",
            "expr": "p_partkey"
          },
          {
            "name": "p_name",
            "expr": "p_name",
            "displayName": "Product Name"
          },
          {
            "name": "p_brand",
            "expr": "p_brand",
            "displayName": "Brand"
          },
          {
            "name": "revenue_rank",
            "expr": "revenue_rank",
            "displayName": "Revenue Rank"
          }
        ]
      }
    }
  ],
